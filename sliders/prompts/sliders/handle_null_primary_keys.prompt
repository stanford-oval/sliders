**Example inspections:**
```sql
-- View all NULL rows with their populated columns
SELECT * FROM null_rows;

-- Check metadata fields for matching evidence
SELECT row_id, document_name, text_header, page_number FROM null_rows;
SELECT row_id, document_name, text_header, page_number FROM context_rows;

-- Compare populated non-PK columns side by side
SELECT 'null' as source, * FROM null_rows
UNION ALL
SELECT 'context' as source, * FROM context_rows;

-- Check for document/header matches
SELECT 
  n.row_id as null_row_id,
  {% for col in null_cols %}c.{{col}} as context_{{col}}, {% endfor %}
  n.document_name = c.document_name as same_doc,
  n.text_header = c.text_header as same_header
FROM null_rows n
CROSS JOIN context_rows c;
```

**If you're ready to process**, output:
- action: "process"
- sql: Your processing SQL that returns processed rows from null_rows
- reasoning: Explain your decision for each NULL row

**Processing SQL Requirements:**
- SELECT from `null_rows` table as your base
- Fill NULL PK columns using CASE statements or COALESCE
- Reference `context_rows` via subqueries or LEFT JOIN
- Return all rows you want to keep; omit rows you want to discard
- Preserve all original columns in the output

**Processing SQL Patterns:**

{% if mode == "document_level" %}
```sql
-- Pattern A: Uniform fill from context
SELECT
  row_id,
  {% for col in primary_key %}
  COALESCE({{col}}, (SELECT {{col}} FROM context_rows LIMIT 1)) AS {{col}},
  {% endfor %}
  other_columns...
FROM null_rows;

-- Pattern B: Row-specific logic
SELECT
  row_id,
  {% for col in primary_key %}
  CASE
    WHEN row_id IN (ids_to_fill_from_context) THEN (SELECT {{col}} FROM context_rows LIMIT 1)
    WHEN row_id IN (ids_to_fill_placeholder) THEN '{{placeholder_text}}'
    ELSE {{col}}
  END AS {{col}},
  {% endfor %}
  other_columns...
FROM null_rows
WHERE row_id NOT IN (discarded_ids);

-- Pattern C: Join-based matching
SELECT
  n.row_id,
  {% for col in primary_key %}
  COALESCE(n.{{col}}, c.{{col}}) AS {{col}},
  {% endfor %}
  n.other_columns...
FROM null_rows n
LEFT JOIN context_rows c ON <join_condition>;
```
{% else %}
```sql
-- Pattern A: Uniform fill from context
SELECT
  row_id,
  {% for col in null_cols %}
  COALESCE({{col}}, (SELECT {{col}} FROM context_rows LIMIT 1)) AS {{col}},
  {% endfor %}
  {% for col in non_null_cols %}{{col}}, {% endfor %}
  other_columns...
FROM null_rows;

-- Pattern B: Row-specific logic
SELECT
  row_id,
  {% for col in null_cols %}
  CASE
    WHEN row_id IN (ids_to_fill_from_context) THEN (SELECT {{col}} FROM context_rows LIMIT 1)
    WHEN row_id IN (ids_to_fill_placeholder) THEN '{{placeholder_text}}'
    ELSE {{col}}
  END AS {{col}},
  {% endfor %}
  {% for col in non_null_cols %}{{col}}, {% endfor %}
  other_columns...
FROM null_rows
WHERE row_id NOT IN (discarded_ids);

-- Pattern C: Join-based matching
SELECT
  n.row_id,
  {% for col in null_cols %}
  COALESCE(n.{{col}}, c.{{col}}) AS {{col}},
  {% endfor %}
  {% for col in non_null_cols %}n.{{col}}, {% endfor %}
  n.other_columns...
FROM null_rows n
LEFT JOIN context_rows c ON <join_condition>;
```
