# ---------------------------------------------------------------------------
# Pick ONE provider. SLIDERS defaults to "azure".
# Set SLIDERS_LLM_PROVIDER=openai to use the public OpenAI API instead.
# ---------------------------------------------------------------------------
SLIDERS_LLM_PROVIDER=azure

# ---- Azure OpenAI ----
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ---- OpenAI (used when SLIDERS_LLM_PROVIDER=openai) ----
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Evaluator LLM (LLM-as-a-judge for benchmarks; optional) ----
EVAL_LLM_PROVIDER=
EVAL_AZURE_OPENAI_ENDPOINT=
EVAL_AZURE_OPENAI_API_KEY=

# ---- Run artifacts ----
SLIDERS_LOGS_DIR=./logs
SLIDERS_RESULTS=./results

# ---- Optional Redis cache for LLM responses. Leave unset to disable. ----
REDIS_HOST=localhost
REDIS_PORT=6379
